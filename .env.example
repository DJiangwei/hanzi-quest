# Hanzi Quest — environment variables
# Copy to `.env.local` for local dev. On Vercel, populate via Marketplace integrations.

# ---------- Clerk (provisioned via Vercel Marketplace) ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional sign-in / sign-up paths if you customize them
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---------- Postgres / Neon (provisioned via Vercel Marketplace) ----------
DATABASE_URL=

# ---------- Vercel AI Gateway ----------
# Auto-injected on Vercel via OIDC. Locally: `vercel env pull .env.local`.
AI_GATEWAY_API_KEY=

# ---------- Vercel Blob (added when needed) ----------
BLOB_READ_WRITE_TOKEN=

# ---------- Local dev ----------
NODE_ENV=development
